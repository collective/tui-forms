{
    "title": "Cookieplone",
    "description": "",
    "version": "2.0",
    "properties": {
        "title": {
            "title": "Project Title",
            "default": "Project Title",
            "validator": "",
            "type": "string"
        },
        "description": {
            "title": "Project Description",
            "default": "A new project using Plone 6.",
            "validator": "",
            "type": "string"
        },
        "project_slug": {
            "title": "Project Slug (Used for repository id)",
            "default": "{{ cookiecutter.title }}",
            "validator": "",
            "type": "string"
        },
        "hostname": {
            "title": "Project URL (without protocol)",
            "default": "{{ cookiecutter.project_slug }}.example.com",
            "validator": "",
            "type": "string"
        },
        "author": {
            "title": "Author",
            "default": "Plone Foundation",
            "validator": "",
            "type": "string"
        },
        "email": {
            "title": "Author E-mail",
            "default": "collective@plone.org",
            "validator": "",
            "type": "string"
        },
        "use_prerelease_versions": {
            "title": "Should we use prerelease versions?",
            "default": "{{ 'No' }}",
            "validator": "",
            "type": "string"
        },
        "plone_version": {
            "title": "Plone Version",
            "default": "{{ cookiecutter.use_prerelease_versions }}",
            "validator": "",
            "type": "string"
        },
        "volto_version": {
            "title": "Volto Version",
            "default": "{{ cookiecutter.use_prerelease_versions }}",
            "validator": "",
            "type": "string"
        },
        "python_package_name": {
            "title": "Python Package Name",
            "default": "{{ cookiecutter.project_slug|replace(' ', '')|replace('-', '.') }}",
            "validator": "",
            "type": "string"
        },
        "frontend_addon_name": {
            "title": "Volto Addon Name",
            "default": "volto-{{ cookiecutter.python_package_name|replace('_', '-')|replace('.', '-') }}",
            "validator": "",
            "type": "string"
        },
        "language_code": {
            "title": "Language",
            "default": "en",
            "validator": "",
            "type": "choice",
            "options": [
                [
                    "en",
                    "English"
                ],
                [
                    "de",
                    "Deutsch"
                ],
                [
                    "es",
                    "Español"
                ],
                [
                    "pt-br",
                    "Português (Brasil)"
                ],
                [
                    "nl",
                    "Nederlands"
                ],
                [
                    "fi",
                    "Suomi"
                ],
                [
                    "it",
                    "Italiano"
                ],
                [
                    "sv",
                    "Svenska"
                ]
            ]
        },
        "github_organization": {
            "title": "GitHub or GitLab username or organization slug from URL",
            "default": "collective",
            "validator": "",
            "type": "string"
        },
        "container_registry": {
            "title": "Container Registry",
            "default": "github",
            "validator": "",
            "type": "choice",
            "options": [
                [
                    "github",
                    "GitHub Container Registry"
                ],
                [
                    "docker_hub",
                    "Docker Hub"
                ],
                [
                    "gitlab",
                    "GitLab"
                ]
            ]
        },
        "devops_storage": {
            "title": "Which persistent storage to use in the deployment stack?",
            "default": "relstorage",
            "validator": "",
            "type": "choice",
            "options": [
                [
                    "relstorage",
                    "RelStorage with PostgreSQL (recommended)"
                ],
                [
                    "zeo",
                    "ZEO with FileStorage"
                ],
                [
                    "filestorage",
                    "Local FileStorage, implies a single backend"
                ]
            ]
        },
        "devops_cache": {
            "title": "Should we setup a caching server?",
            "default": "1",
            "validator": "",
            "type": "choice",
            "options": [
                [
                    "1",
                    "Yes"
                ],
                [
                    "0",
                    "No"
                ]
            ]
        },
        "devops_ansible": {
            "title": "Add Ansible playbooks?",
            "default": "1",
            "validator": "",
            "type": "choice",
            "options": [
                [
                    "1",
                    "Yes"
                ],
                [
                    "0",
                    "No"
                ]
            ]
        },
        "devops_gha_deploy": {
            "title": "Add GitHub Action to Deploy this project?",
            "default": "1",
            "validator": "",
            "type": "choice",
            "options": [
                [
                    "1",
                    "Yes"
                ],
                [
                    "0",
                    "No"
                ]
            ]
        },
        "initialize_documentation": {
            "title": "Would you like to add a documentation scaffold to your project?",
            "default": "1",
            "validator": "",
            "type": "choice",
            "options": [
                [
                    "1",
                    "Yes"
                ],
                [
                    "0",
                    "No"
                ]
            ]
        },
        "__project_slug": {
            "title": "__project_slug",
            "default": "{{ cookiecutter.project_slug }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__repository_url": {
            "title": "__repository_url",
            "default": "https://github.com/{{ cookiecutter.github_organization }}/{{ cookiecutter.__project_slug }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__repository_git": {
            "title": "__repository_git",
            "default": "git@github.com:{{ cookiecutter.github_organization }}/{{ cookiecutter.__project_slug }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__version_package": {
            "title": "__version_package",
            "default": "1.0.0a0",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__version_frontend_package": {
            "title": "__version_frontend_package",
            "default": "1.0.0-alpha.0",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__feature_headless": {
            "title": "__feature_headless",
            "default": "1",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__feature_distribution": {
            "title": "__feature_distribution",
            "default": "0",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__backend_managed_by_uv": {
            "title": "__backend_managed_by_uv",
            "default": "false",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__frontend_package_name": {
            "title": "__frontend_package_name",
            "default": "{{ cookiecutter.frontend_addon_name }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__npm_package_name": {
            "title": "__npm_package_name",
            "default": "{{ cookiecutter.frontend_addon_name }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__folder_name": {
            "title": "__folder_name",
            "default": "{{ cookiecutter.project_slug }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__python_package_name_upper": {
            "title": "__python_package_name_upper",
            "default": "{{ cookiecutter.python_package_name }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__python_version": {
            "title": "__python_version",
            "default": "3.13",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__node_version": {
            "title": "__node_version",
            "default": "{{ cookiecutter.volto_version }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__version_plone_volto": {
            "title": "__version_plone_volto",
            "default": "{{ cookiecutter.volto_version }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__version_pnpm": {
            "title": "__version_pnpm",
            "default": "{{ '10.20.0' if cookiecutter.volto_version >= '19' else '9.1.1' }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__container_registry_prefix": {
            "title": "__container_registry_prefix",
            "default": "{{ cookiecutter.container_registry }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__container_image_prefix": {
            "title": "__container_image_prefix",
            "default": "{{ cookiecutter.__container_registry_prefix }}{{ cookiecutter.github_organization }}/{{ cookiecutter.project_slug }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__profile_version": {
            "title": "__profile_version",
            "default": "{% now 'utc', '%Y%m%d001' %}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__profile_language": {
            "title": "__profile_language",
            "default": "{{ cookiecutter.language_code }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__locales_language": {
            "title": "__locales_language",
            "default": "{{ cookiecutter.language_code }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__devops_host": {
            "title": "__devops_host",
            "default": "{{ cookiecutter.hostname }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__devops_compose_name": {
            "title": "__devops_compose_name",
            "default": "{{ cookiecutter.project_slug | replace('.','-') | replace('_','-') }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__devops_stack_name": {
            "title": "__devops_stack_name",
            "default": "{{ cookiecutter.hostname | replace('.','-') | replace('_','-') }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__devops_swarm_public_network": {
            "title": "__devops_swarm_public_network",
            "default": "nw-public",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__devops_swarm_stack_network": {
            "title": "__devops_swarm_stack_network",
            "default": "nw-internal",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__devops_traefik_version": {
            "title": "__devops_traefik_version",
            "default": "v2.11",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__devops_traefik_local_include_ui": {
            "title": "__devops_traefik_local_include_ui",
            "default": "yes",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__devops_traefik_stack_include_ui": {
            "title": "__devops_traefik_stack_include_ui",
            "default": "no",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__devops_traefik_docker_network": {
            "title": "__devops_traefik_docker_network",
            "default": "{{ cookiecutter.__devops_stack_name }}_{{ cookiecutter.__devops_swarm_stack_network }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__devops_varnish_version": {
            "title": "__devops_varnish_version",
            "default": "7.6",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__devops_db_version": {
            "title": "__devops_db_version",
            "default": "14.15",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__devops_db_password": {
            "title": "__devops_db_password",
            "default": "{{ random_ascii_string(12) }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__devops_zeo_version": {
            "title": "__devops_zeo_version",
            "default": "6.0.0",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__backend_addon_git_initialize": {
            "title": "__backend_addon_git_initialize",
            "default": "0",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__backend_addon_format": {
            "title": "__backend_addon_format",
            "default": "1",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__project_git_initialize": {
            "title": "__project_git_initialize",
            "default": "1",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "_copy_without_render": {
            "title": "_copy_without_render",
            "default": [
                "devops/etc",
                "devops/playbooks",
                "devops/requirements",
                "devops/tasks",
                "devops/inventory/group_vars/all/users.yml",
                "news/.changelog_template.jinja"
            ],
            "validator": "",
            "type": "array",
            "format": "constant"
        },
        "_extensions": {
            "title": "_extensions",
            "default": [
                "cookieplone.filters.use_prerelease_versions",
                "cookieplone.filters.node_version_for_volto",
                "cookieplone.filters.extract_host",
                "cookieplone.filters.image_prefix",
                "cookieplone.filters.pascal_case",
                "cookieplone.filters.locales_language_code",
                "cookieplone.filters.gs_language_code",
                "cookieplone.filters.unscoped_package_name",
                "cookieplone.filters.latest_volto",
                "cookieplone.filters.latest_plone"
            ],
            "validator": "",
            "type": "array",
            "format": "constant"
        },
        "__cookieplone_subtemplates": {
            "title": "__cookieplone_subtemplates",
            "default": [
                [
                    "add-ons/backend",
                    "Setup Backend",
                    "1"
                ],
                [
                    "add-ons/frontend",
                    "Setup Frontend",
                    "1"
                ],
                [
                    "docs/starter",
                    "Generate documentation scaffold",
                    "{{cookiecutter.initialize_documentation}}"
                ],
                [
                    "sub/cache",
                    "Setup Cache",
                    "{{cookiecutter.devops_cache}}"
                ],
                [
                    "sub/project_settings",
                    "Setup Project Settings",
                    "1"
                ],
                [
                    "ide/vscode",
                    "Setup VSCode configuration",
                    "1"
                ],
                [
                    "ci/gh_project",
                    "Setup GitHub CI",
                    "1"
                ]
            ],
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__cookieplone_repository_path": {
            "title": "__cookieplone_repository_path",
            "default": "",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__cookieplone_template": {
            "title": "__cookieplone_template",
            "default": "project",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__generator_sha": {
            "title": "__generator_sha",
            "default": "",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__generator_template_url": {
            "title": "__generator_template_url",
            "default": "https://github.com/plone/cookieplone-templates/tree/main/{{ cookiecutter.__cookieplone_template }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__generator_date_long": {
            "title": "__generator_date_long",
            "default": "{% now 'utc', '%Y-%m-%d %H:%M:%S' %}",
            "validator": "",
            "type": "string",
            "format": "computed"
        },
        "__generator_signature": {
            "title": "__generator_signature",
            "default": "This was generated by [the cookieplone-templates {{ cookiecutter.__cookieplone_template }} template]({{ cookiecutter.__generator_template_url }}) on {{ cookiecutter.__generator_date_long }}",
            "validator": "",
            "type": "string",
            "format": "computed"
        }
    }
}
